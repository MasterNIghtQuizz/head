{
  "uid": "status-page",
  "title": "Platform Status Page",
  "description": "Ready/Alive status of all platform components",
  "tags": ["quizz-master", "status"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Microservices",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "API Gateway",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        }
      },
      "targets": [{ "expr": "max(service_up{service=\"api-gateway\"}) or vector(0)", "instant": true }]
    },
    {
