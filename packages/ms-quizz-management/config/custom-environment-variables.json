{
  "app": {
    "port": "PORT",
    "env": "NODE_ENV"
  },
  "logger": {
    "level": "LOG_LEVEL"
  },
  "postgres": {
    "host": "POSTGRES_HOST",
    "port": "POSTGRES_PORT",
    "database": "POSTGRES_DB",
    "user": "POSTGRES_USER",
    "password": "POSTGRES_PASSWORD"
  },
  "auth": {
    "internal": {
      "privateKeyPath": "AUTH_INTERNAL_PRIVATE_KEY_PATH",
      "publicKeyPath": "AUTH_INTERNAL_PUBLIC_KEY_PATH",
      "privateKey": "AUTH_INTERNAL_PRIVATE_KEY",
      "publicKey": "AUTH_INTERNAL_PUBLIC_KEY"
    }
  },
  "kafka": {
    "enabled": "KAFKA_ENABLED",
    "brokers": {
      "__name": "KAFKA_BROKERS",
      "__format": "json"
    }
  },
  "valkey": {
    "enabled": "VALKEY_ENABLED",
    "host": "VALKEY_HOST",
    "port": "VALKEY_PORT",
    "password": "VALKEY_PASSWORD",
    "db": "VALKEY_DB",
    "ttl": "VALKEY_TTL"
  }
}
