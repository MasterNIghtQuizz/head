{
  "app": {
    "port": 3010,
    "env": "development"
  },
  "logger": {
    "level": "info",
    "pretty": true
  },
  "services": {
    "user": "http://localhost:4001",
    "quizz": "http://localhost:4002",
    "websocket": "http://localhost:3333",
    "session": "http://localhost:4003"
  },
  "auth": {
    "access": {
      "privateKeyPath": "../../keys/access-private.pem",
      "publicKeyPath": "../../keys/access-public.pem"
    },
    "refresh": {
      "privateKeyPath": "../../keys/refresh-private.pem",
      "publicKeyPath": "../../keys/refresh-public.pem"
    },
    "internal": {
      "privateKeyPath": "../../keys/internal-private.pem",
      "publicKeyPath": "../../keys/internal-public.pem"
    },
    "game": {
      "privateKeyPath": "../../keys/game-private.pem",
      "publicKeyPath": "../../keys/game-public.pem"
    }
  },
  "kafka": {
    "brokers": ["localhost:9092"]
  },
  "valkey": {
    "host": "localhost",
    "port": 6379,
    "password": "",
    "db": 0,
    "ttl": 3600
  },
  "otel": {
    "enabled": false,
    "exporterUrl": "http://localhost:4317"
  },
  "opensearch": {
    "enabled": false,
    "node": "http://localhost:9200",
    "index": "logs-api-gateway"
  },
  "metrics": {
    "enabled": true
  }
}
