{
  "app": {
    "port": "PORT",
    "env": "NODE_ENV",
    "frontendUrl": "FRONTEND_URL"
  },
  "logger": {
    "level": "LOG_LEVEL",
    "pretty": {
      "__name": "LOG_PRETTY",
      "__format": "json"
    }
  },
  "services": {
    "user": "USER_SERVICE_URL",
    "quizz": "QUIZZ_SERVICE_URL",
    "websocket": "WEBSOCKET_SERVICE_URL",
    "session": "SESSION_SERVICE_URL"
  },
  "auth": {
    "access": {
      "privateKeyPath": "AUTH_ACCESS_PRIVATE_KEY_PATH",
      "publicKeyPath": "AUTH_ACCESS_PUBLIC_KEY_PATH",
      "privateKey": "AUTH_ACCESS_PRIVATE_KEY",
      "publicKey": "AUTH_ACCESS_PUBLIC_KEY"
    },
    "refresh": {
      "privateKeyPath": "AUTH_REFRESH_PRIVATE_KEY_PATH",
      "publicKeyPath": "AUTH_REFRESH_PUBLIC_KEY_PATH",
      "privateKey": "AUTH_REFRESH_PRIVATE_KEY",
      "publicKey": "AUTH_REFRESH_PUBLIC_KEY"
    },
    "internal": {
      "privateKeyPath": "AUTH_INTERNAL_PRIVATE_KEY_PATH",
      "publicKeyPath": "AUTH_INTERNAL_PUBLIC_KEY_PATH",
      "privateKey": "AUTH_INTERNAL_PRIVATE_KEY",
      "publicKey": "AUTH_INTERNAL_PUBLIC_KEY"
    },
    "game": {
      "privateKeyPath": "AUTH_GAME_PRIVATE_KEY_PATH",
      "publicKeyPath": "AUTH_GAME_PUBLIC_KEY_PATH",
      "privateKey": "AUTH_GAME_PRIVATE_KEY",
      "publicKey": "AUTH_GAME_PUBLIC_KEY"
    }
  },
  "kafka": {
    "brokers": {
      "__name": "KAFKA_BROKERS",
      "__format": "json"
    }
  },
  "valkey": {
    "enabled": "VALKEY_ENABLED",
    "host": "VALKEY_HOST",
    "port": "VALKEY_PORT",
    "password": "VALKEY_PASSWORD",
    "db": "VALKEY_DB",
    "ttl": "VALKEY_TTL"
  },
  "otel": {
    "enabled": {
      "__name": "OTEL_ENABLED",
      "__format": "json"
    },
    "exporterUrl": "OTEL_EXPORTER_OTLP_ENDPOINT"
  },
  "opensearch": {
    "enabled": {
      "__name": "OPENSEARCH_ENABLED",
      "__format": "json"
    },
    "node": "OPENSEARCH_NODE",
    "index": "OPENSEARCH_INDEX",
    "auth": {
      "username": "OPENSEARCH_USERNAME",
      "password": "OPENSEARCH_PASSWORD"
    },
    "ssl": {
      "rejectUnauthorized": {
        "__name": "OPENSEARCH_SSL_REJECT_UNAUTHORIZED",
        "__format": "json"
      }
    }
  },
  "metrics": {
    "enabled": {
      "__name": "METRICS_ENABLED",
      "__format": "json"
    }
  }
}
