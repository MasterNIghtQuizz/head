{
  "app": {
    "port": "PORT",
    "env": "NODE_ENV"
  },
  "logger": {
    "level": "LOG_LEVEL",
    "pretty": {
      "__name": "LOG_PRETTY",
      "__format": "json"
    }
  },
  "auth": {
    "access": {
      "privateKeyPath": "AUTH_ACCESS_PRIVATE_KEY_PATH",
      "publicKeyPath": "AUTH_ACCESS_PUBLIC_KEY_PATH",
      "privateKey": "AUTH_ACCESS_PRIVATE_KEY",
      "publicKey": "AUTH_ACCESS_PUBLIC_KEY"
    },
    "refresh": {
      "privateKeyPath": "AUTH_REFRESH_PRIVATE_KEY_PATH",
      "publicKeyPath": "AUTH_REFRESH_PUBLIC_KEY_PATH",
      "privateKey": "AUTH_REFRESH_PRIVATE_KEY",
      "publicKey": "AUTH_REFRESH_PUBLIC_KEY"
    },
    "internal": {
      "privateKeyPath": "AUTH_INTERNAL_PRIVATE_KEY_PATH",
      "publicKeyPath": "AUTH_INTERNAL_PUBLIC_KEY_PATH",
      "privateKey": "AUTH_INTERNAL_PRIVATE_KEY",
      "publicKey": "AUTH_INTERNAL_PUBLIC_KEY"
    }
  },
  "kafka": {
    "enabled": "KAFKA_ENABLED",
    "brokers": {
      "__name": "KAFKA_BROKERS",
      "__format": "json"
    }
  },
  "valkey": {
    "enabled": "VALKEY_ENABLED",
    "host": "VALKEY_HOST",
    "port": "VALKEY_PORT",
    "password": "VALKEY_PASSWORD",
    "db": "VALKEY_DB"
  },
  "otel": {
    "enabled": {
      "__name": "OTEL_ENABLED",
      "__format": "json"
    },
    "exporterUrl": "OTEL_EXPORTER_OTLP_ENDPOINT"
  },
  "opensearch": {
    "enabled": {
      "__name": "OPENSEARCH_ENABLED",
      "__format": "json"
    },
    "node": "OPENSEARCH_NODE",
    "index": "OPENSEARCH_INDEX"
  }
}
