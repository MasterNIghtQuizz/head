{
  "app": {
    "port": 4003,
    "env": "development"
  },
  "logger": {
    "level": "info",
    "pretty": true
  },
  "postgres": {
    "host": "localhost",
    "port": 5433,
    "database": "ms_session_db",
    "user": "postgres",
    "password": "postgres_password"
  },
  "auth": {
    "access": {
      "privateKeyPath": "../../keys/access-private.pem",
      "publicKeyPath": "../../keys/access-public.pem"
    },
    "refresh": {
      "privateKeyPath": "../../keys/refresh-private.pem",
      "publicKeyPath": "../../keys/refresh-public.pem"
    },
    "internal": {
      "privateKeyPath": "../../keys/internal-private.pem",
      "publicKeyPath": "../../keys/internal-public.pem"
    }
  },
  "kafka": {
    "brokers": ["localhost:9092"],
    "enabled": true
  },
  "valkey": {
    "host": "localhost",
    "port": 6379,
    "password": "",
    "db": 0,
    "ttl": 3600
  },
  "otel": {
    "enabled": false,
    "exporterUrl": "http://localhost:4317"
  },
  "services": {
    "session": {
      "baseUrl": "http://localhost:4003"
    },
    "quizzManagement": {
      "baseUrl": "http://localhost:4002"
    }
  }
}
