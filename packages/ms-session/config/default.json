{
  "app": {
    "port": 4001,
    "env": "development"
  },
  "logger": {
    "level": "info",
    "pretty": true
  },
  "postgres": {
    "host": "localhost",
    "port": 5433,
    "database": "ms_session_db",
    "user": "postgres",
    "password": "postgres_password"
  },
  "auth": {
    "access": {
      "privateKeyPath": "../../keys/access-private.pem",
      "publicKeyPath": "../../keys/access-public.pem"
    },
    "refresh": {
      "privateKeyPath": "../../keys/refresh-private.pem",
      "publicKeyPath": "../../keys/refresh-public.pem"
    },
    "internal": {
      "privateKeyPath": "../../keys/internal-private.pem",
      "publicKeyPath": "../../keys/internal-public.pem"
    }
  },
  "kafka": {
    "brokers": [
      "localhost:9092"
    ]
  },
  "otel": {
    "enabled": false,
    "exporterUrl": "http://localhost:4317"
  },
  "services": {
    "quizzManagement": {
      "baseUrl": "http://ms-quizz-management:4002"
    }
  }
}
