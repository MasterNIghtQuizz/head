{
  "app": {
    "port": "PORT",
    "env": "NODE_ENV"
  },
  "logger": {
    "level": "LOG_LEVEL"
  },
  "postgres": {
    "host": "POSTGRES_HOST",
    "port": "POSTGRES_PORT",
    "database": "POSTGRES_DB",
    "user": "POSTGRES_USER",
    "password": "POSTGRES_PASSWORD"
  },
  "auth": {
    "internal": {
      "privateKeyPath": "AUTH_INTERNAL_PRIVATE_KEY_PATH",
      "publicKeyPath": "AUTH_INTERNAL_PUBLIC_KEY_PATH"
    },
    "game": {
      "privateKeyPath": "AUTH_GAME_PRIVATE_KEY_PATH",
      "publicKeyPath": "AUTH_GAME_PUBLIC_KEY_PATH"
    }
  },
  "kafka": {
    "brokers": {
      "__name": "KAFKA_BROKERS",
      "__format": "json"
    },
    "enabled": "KAFKA_ENABLED"
  },
  "valkey": {
    "enabled": "VALKEY_ENABLED",
    "host": "VALKEY_HOST",
    "port": "VALKEY_PORT",
    "password": "VALKEY_PASSWORD",
    "db": "VALKEY_DB"
  },
  "opensearch": {
    "enabled": {
      "__name": "OPENSEARCH_ENABLED",
      "__format": "json"
    },
    "node": "OPENSEARCH_NODE",
    "index": "OPENSEARCH_INDEX",
    "auth": {
      "username": "OPENSEARCH_USERNAME",
      "password": "OPENSEARCH_PASSWORD"
    },
    "ssl": {
      "rejectUnauthorized": {
        "__name": "OPENSEARCH_SSL_REJECT_UNAUTHORIZED",
        "__format": "json"
      }
    }
  },
  "otel": {
    "enabled": {
      "__name": "OTEL_ENABLED",
      "__format": "json"
    },
    "exporterUrl": "OTEL_EXPORTER_OTLP_ENDPOINT"
  },
  "services": {
    "session": {
      "baseUrl": "SESSION_SERVICE_URL"
    },
    "quizzManagement": {
      "baseUrl": "QUIZZ_SERVICE_URL"
    }
  },
  "metrics": {
    "enabled": {
      "__name": "METRICS_ENABLED",
      "__format": "json"
    }
  }
}
