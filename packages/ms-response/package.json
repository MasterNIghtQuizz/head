{
  "name": "@monorepo/ms-response",
  "version": "1.0.0",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "migrations:run": "node src/run-migrations.js",
    "lint": "yarn run -T eslint .",
    "lint:fix": "yarn run -T eslint . --fix",
    "test": "yarn run -T vitest run",
