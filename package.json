{
  "name": "monorepo",
  "type": "module",
  "packageManager": "yarn@4.11.0",
  "workspaces": [
    "packages/**"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "concurrently -k -p \"[{name}]\" -n \"GATEWAY,USER,QUIZZ,SESSION,RESPONSE,WS\" -c \"cyan,green,yellow,magenta,red,purple\" \"yarn workspace @monorepo/api-gateway start\" \"yarn workspace @monorepo/ms-user start\" \"yarn workspace @monorepo/ms-quizz-management start\" \"yarn workspace @monorepo/ms-session start\" \"yarn workspace @monorepo/ms-response start\" \"yarn workspace @monorepo/ws-service start\"",
    "eslint": "npx eslint",
    "lint": "npx eslint . --fix",
    "format": "npx prettier --write .",
    "vitest": "npx vitest",
    "test": "npx vitest",
    "test:unit": "npx vitest run --config vitest.config.js",
    "test:int": "npx vitest run --config vitest.config.int.js",
    "test:e2e": "bash scripts/run-e2e.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.0.0",
    "eslint-plugin-prettier": "^5.2.0",
    "eslint-plugin-unicorn": "^56.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@fastify/http-proxy": "11.4.3",
    "@fastify/swagger": "^9.0.0",
    "@fastify/swagger-ui": "^5.0.0",
    "fastify": "^5.8.4"
  },
  "resolutions": {
    "typeorm": "0.3.28",
    "reflect-metadata": "0.2.2"
  }
}
